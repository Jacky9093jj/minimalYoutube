{
  "manifest_version": 3,
  "name": "minimalYoutube",
  "version": "1.0.0",
  "description": "Hide recommendations, comments, shorts, etc.",
  "permissions": ["storage"],
  "host_permissions": ["*://www.youtube.com/*", "*://youtube.com/*"],
  "action": {
    "default_title": "minimalYoutube",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*", "*://youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

